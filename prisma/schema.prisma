generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String      @id @default(uuid())
  email            String?     @unique
  phone            String?     @unique
  passwordHash     String      @map("password_hash")
  role             String      @default("user") // user | admin | super_admin
  nickname         String?
  avatar           String?
  status           String      @default("active") // active | blocked
  trialExpiresAt   DateTime    @map("trial_expires_at")
  isSubscribed     Boolean     @default(false) @map("is_subscribed")
  subscriptionPlan String?     @map("subscription_plan")
  credits          Int         @default(0)
  // 积分过期（17.3）
  creditsExpiresAt DateTime?   @map("credits_expires_at")
  creditsExpired   Boolean     @default(false) @map("credits_expired")
  totalUsed        Int         @default(0) @map("total_used")
  // 邀请裂变（13.4）
  inviteCode       String?     @unique @map("invite_code") // 用户专属邀请码
  inviterId        String?     @map("inviter_id") // 邀请人 ID
  inviteCount      Int         @default(0) @map("invite_count") // 成功邀请人数
  inviteReward     Int         @default(0) @map("invite_reward") // 邀请奖励总积分
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  // 邀请关系：inviter 是邀请人，invitees 是被该用户邀请的人
  inviter               User?       @relation("UserInvite", fields: [inviterId], references: [id], onDelete: SetNull)
  invitees              User[]      @relation("UserInvite")

  usageLogs            UsageLog[]
  apiKeys              ApiKey[]
  orders               Order[]
  callLogs             CallLog[]
  notifications        Notification[]
  actionLogsAsOperator ActionLog[] @relation("ActionLogOperator")
  actionLogsAsTarget   ActionLog[] @relation("ActionLogTarget")
  eventLogs            EventLog[]
  progresses           UserProgress[]

  @@index([inviterId])
  @@map("users")
}

// 学习进度追踪模型
// 开发完成后需要执行: npx prisma db push 或执行 SQL 脚本同步到数据库
model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  pathId    String   // 学习路径 ID，如 "ecommerce-ai-7days"
  stepId    String   // 教程步骤 ID
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId, stepId])
  @@index([userId, pathId])
  @@map("user_progresses")
}

model ApiKey {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  keyPrefix     String    @map("key_prefix")
  keyHash       String    @unique @map("key_hash")
  name          String
  status        String    @default("active") // active | inactive | revoked
  creditsUsed   Int       @default(0) @map("credits_used")
  totalCalls    Int       @default(0) @map("total_calls")
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // 频率限制（Phase 3.4）
  // qpsLimit：单 Key 每秒最大请求数（0 表示不限制）
  qpsLimit      Int       @default(5) @map("qps_limit")
  // dailyLimit：单 Key 每日最大调用次数（0 表示不限制）
  dailyLimit    Int       @default(1000) @map("daily_limit")
  // dailyUsed：今日已调用次数（每日 UTC 0 点重置）
  dailyUsed     Int       @default(0) @map("daily_used")
  // dailyResetAt：下次重置时间（UTC 0 点）
  dailyResetAt  DateTime  @default(now()) @map("daily_reset_at")

  // Webhook 配置（Phase 3.6）
  // webhookUrl：长任务完成时主动通知的 URL（HTTPS 推荐）
  webhookUrl    String?   @map("webhook_url")
  // webhookSecret：HMAC-SHA256 签名密钥（用于校验通知真实性）
  webhookSecret String?   @map("webhook_secret")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  callLogs CallLog[]

  @@index([userId])
  @@map("api_keys")
}

model CallLog {
  id           String    @id @default(uuid())
  apiKeyId     String    @map("api_key_id")
  userId       String    @map("user_id")
  workflowId   String?   @map("workflow_id")
  endpoint     String
  method       String
  creditsCost  Int       @default(0) @map("credits_cost")
  status       String    @default("success") // success | failed
  errorMessage String?   @map("error_message")
  responseTime Int?      @map("response_time")
  clientIp     String?   @map("client_ip")
  // 真实 API 成本（元），用于成本核算（Phase 13.3）
  apiCost      Decimal   @db.Decimal(10, 4) @default(0) @map("api_cost")
  createdAt    DateTime  @default(now()) @map("created_at")

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([userId, createdAt])
  @@map("call_logs")
}

model Order {
  id            String    @id @default(uuid())
  orderNo       String    @unique @map("order_no")
  userId        String    @map("user_id")
  type          String    // subscription | credits
  planId        String?   @map("plan_id")
  credits       Int       @default(0)
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("pending") // pending | paid | failed | refunded
  paymentMethod String?   @map("payment_method")
  paymentId     String?   @map("payment_id")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  // 退费相关字段（Phase 13.2）
  refundStatus  String    @default("none") @map("refund_status") // none | requested | refunded | rejected
  refundReason  String?   @map("refund_reason")
  refundedAt    DateTime? @map("refunded_at")
  refundAmount Decimal?   @db.Decimal(10, 2) @map("refund_amount")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([planId])
  @@map("orders")
}

model UsageLog {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  workflowId   String    @map("workflow_id")
  taskId       String?   @map("task_id")
  status       String    @default("pending")
  tokensUsed   Int       @default(0) @map("tokens_used")
  inputUrl     String?   @map("input_url")
  outputUrl    String?   @map("output_url")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")
  creditsCost  Int       @default(0) @map("credits_cost")
  source       String    @default("direct") // direct | api
  thumbnail    String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([workflowId])
  @@map("usage_logs")
}

model Plan {
  id            String   @id @default(uuid())
  name          String   @unique
  dailyLimit    Int      @map("daily_limit")
  monthlyPrice  Decimal  @db.Decimal(10, 2) @map("monthly_price")
  features      Json
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("plans")
}

model Workflow {
  id              String    @id @default(uuid())
  name            String
  description     String?
  category        String
  cozeWorkflowId  String    @map("coze_workflow_id")
  coverImage      String?   @map("cover_image")
  inputSchema     Json?     @map("input_schema")
  outputType      String    @default("text") @map("output_type")
  creditsRequired Int       @default(1) @map("credits_required")
  source          String    @default("coze") // coze | volcengine
  volcModel       String?   @map("volc_model")
  icon            String?
  status          String    @default("active")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  feishuDocUrl    String?   @map("feishu_doc_url")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  usageLogs       UsageLog[]

  @@index([status, sortOrder])
  @@index([category])
  @@map("workflows")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // task_complete | system | announcement
  title     String
  content   String?
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model ActionLog {
  id           String   @id @default(uuid())
  operatorId   String   @map("operator_id")
  targetUserId String?  @map("target_user_id")
  action       String   // block | unblock | update_credits | update_plan | set_role
  detail       Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  operator   User  @relation("ActionLogOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  targetUser User? @relation("ActionLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([operatorId, createdAt])
  @@index([targetUserId])
  @@map("action_logs")
}

/// 用户行为埋点日志（18.1）
model EventLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  event      String // page_view | button_click | workflow_run | chat_message | register | login | purchase
  properties Json?
  clientIp   String? @map("client_ip")
  userAgent  String? @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("event_logs")
}

/// 首页轮播图（Phase 2）
model CarouselSlide {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  link        String?
  badge       String?
  sortOrder   Int      @default(0) @map("sort_order")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([published, sortOrder])
  @@map("carousel_slides")
}

/// 图文+视频教程（Phase 2）
model Tutorial {
  id          String   @id @default(cuid())
  type        String // article | video
  title       String
  category    String?
  cover       String?
  content     String?
  videoUrl    String?  @map("video_url")
  excerpt     String?
  sortOrder   Int      @default(0) @map("sort_order")
  published   Boolean  @default(false)
  studyCount  Int      @default(0) @map("study_count")
  viewCount   Int      @default(0) @map("view_count")
  accessLevel String   @default("free") @map("access_level") // free | vip
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([published, sortOrder])
  @@index([type])
  @@map("tutorials")
}
