# =============================================================================
# 燃渡AI - 生产环境变量模板
# =============================================================================
# 使用方式：
# 1. 复制本文件为 .env.production
# 2. 填写真实值
# 3. 切勿将 .env.production 提交到 Git
# =============================================================================

# ---------- 数据库 ----------
# PostgreSQL 用户名（与 docker-compose.yml 保持一致）
POSTGRES_USER=randu

# PostgreSQL 密码（请使用强密码！）
# 生成方式：openssl rand -base64 24
POSTGRES_PASSWORD=请替换为强密码

# 数据库名称
POSTGRES_DB=randu_ai

# ---------- Coze API ----------
COZE_API_TOKEN=your_coze_api_token
COZE_BASE_URL=https://api.coze.cn

# ---------- 阿里云 OSS ----------
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=randu-ai
OSS_REGION=oss-cn-chengdu
# CDN 域名（如有配置则填写，没有则留空）
OSS_CDN_DOMAIN=

# ---------- JWT 密钥 ----------
# 生成方式：openssl rand -base64 32
JWT_SECRET=请替换为32位以上的随机字符串

# ---------- 应用配置 ----------
# 备案通过后改为：https://randuai.cn
NEXT_PUBLIC_APP_URL=http://47.108.249.252:3000
