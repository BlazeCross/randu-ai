# =============================================================================
# 燃渡AI - 生产环境变量模板
# =============================================================================
# 使用方式：
# 1. 复制本文件为 .env.production
# 2. 填写真实值
# 3. 切勿将 .env.production 提交到 Git
# =============================================================================

# ---------- 数据库 ----------
# PostgreSQL 用户名（与 docker-compose.yml 保持一致）
POSTGRES_USER=randu

# PostgreSQL 密码（请使用强密码！）
# 生成方式：openssl rand -base64 24
POSTGRES_PASSWORD=请替换为强密码

# 数据库名称
POSTGRES_DB=randu_ai

# ---------- Coze API ----------
COZE_API_TOKEN=your_coze_api_token
COZE_BASE_URL=https://api.coze.cn

# ---------- 阿里云 OSS ----------
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=randu-ai
OSS_REGION=oss-cn-chengdu
# CDN 域名（如有配置则填写，没有则留空）
OSS_CDN_DOMAIN=

# ---------- 阿里云 STS（前端直传 OSS 临时凭证，可选）----------
# 若未配置，前端会自动回退到服务端中转上传模式
# 获取方式：RAM 控制台 → 创建子账号 → 创建角色并授权 oss:PutObject
ALIYUN_STS_ACCESS_KEY_ID=
ALIYUN_STS_ACCESS_KEY_SECRET=
ALIYUN_STS_ROLE_ARN=

# ---------- 火山方舟 AI 模型 ----------
VOLC_ARK_API_KEY=your_volc_ark_api_key
VOLC_MODEL_DOUBAO=doubao-pro-32k
VOLC_MODEL_SEEDREAM=seedream-3-0-t2i-250415
# Seedance 视频生成模型（可选，未配置则视频生成接口不可用）
VOLC_MODEL_SEEDANCE=

# ---------- 支付宝（可选，未配置则充值功能不可用）----------
# 获取方式：https://open.alipay.com → 控制台 → 我的应用 → 创建网页应用
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# 异步通知地址（需公网可访问，https 域名）
ALIPAY_NOTIFY_URL=https://randuai.cn/api/alipay/notify
# 同步跳转地址（支付完成后浏览器跳转）
ALIPAY_RETURN_URL=https://randuai.cn/dashboard

# ---------- JWT 密钥 ----------
# 生成方式：openssl rand -base64 32
JWT_SECRET=请替换为32位以上的随机字符串

# ---------- 应用配置 ----------
NEXT_PUBLIC_APP_URL=https://randuai.cn
