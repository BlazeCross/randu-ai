# =============================================================================
# 燃渡 AI 工作流 - 环境变量示例
# =============================================================================
# 使用说明：
# 1. 复制本文件为 .env.local（本地开发）或在部署平台配置对应变量
# 2. 将下列占位符替换为真实值
# 3. 切勿将 .env.local 提交到 Git（已在 .gitignore 中忽略）
# =============================================================================

# -----------------------------------------------------------------------------
# Coze API（核心：AI 工作流执行引擎）
# -----------------------------------------------------------------------------
# 获取方式：登录 Coze 平台 (https://www.coze.cn) → 个人中心 → API 访问令牌
# 用途：调用 Coze 工作流异步接口（提交任务、查询状态）
COZE_API_TOKEN=your_coze_api_token

# Coze API 基础地址
# 国内用户默认 https://api.coze.cn，海外用户使用 https://api.coze.com
COZE_BASE_URL=https://api.coze.cn

# -----------------------------------------------------------------------------
# 阿里云 OSS（对象存储：用户上传图片 & 生成视频存储）
# -----------------------------------------------------------------------------
# 获取方式：阿里云控制台 → RAM 访问控制 → 创建 AccessKey
# 安全建议：使用 RAM 子账号，仅授予 OSS 读写权限，不要使用主账号 AK
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# OSS Bucket 名称（需全局唯一）
OSS_BUCKET=your_bucket_name

# OSS 地域（与 Bucket 创建时选择的地域一致）
# 参考：https://help.aliyun.com/document_detail/31837.htm
OSS_REGION=oss-cn-hangzhou

# OSS CDN 域名（用于拼接文件访问 URL）
# 获取方式：阿里云 CDN 控制台 → 添加加速域名，回源指向 OSS Bucket
# 格式：https://your-cdn-domain.com（结尾不要加斜杠）
OSS_CDN_DOMAIN=https://your-cdn-domain.com

# -----------------------------------------------------------------------------
# 数据库（PostgreSQL）
# -----------------------------------------------------------------------------
# 生产环境连接串格式：
#   postgresql://用户名:密码@主机:端口/数据库名?schema=public
# 示例（阿里云 RDS）：
#   postgresql://randu:strong_password@rm-xxxx.pg.rds.aliyuncs.com:5432/randu_ai?schema=public
# 本地开发：
#   postgresql://user:password@localhost:5432/randu_ai
# 注意：密码中如含特殊字符（@、#、: 等）需做 URL 编码
DATABASE_URL=postgresql://user:password@localhost:5432/randu_ai

# -----------------------------------------------------------------------------
# JWT（用户认证 Token 签名密钥）
# -----------------------------------------------------------------------------
# 生产环境必须使用强密钥（≥32 字符随机字符串）
# 生成方式（任选其一）：
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 警告：密钥泄露将导致所有用户 Token 可被伪造，请妥善保管
JWT_SECRET=your_jwt_secret_key

# -----------------------------------------------------------------------------
# 飞书文档（工作流使用说明外链）
# -----------------------------------------------------------------------------
# 各工作流对应的飞书文档地址，用于前端"使用说明"跳转
# 也可在数据库 workflows 表的 feishu_doc_url 字段为每个工作流单独配置
FEISHU_DOC_URL=https://your-feishu-doc-url.com

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
# 应用对外访问的完整 URL（含协议，结尾不要加斜杠）
# 本地开发：http://localhost:3000
# 生产环境：https://your-domain.com
# 用途：
#   - Next.js 构建时内联到客户端代码（NEXT_PUBLIC_* 前缀）
#   - OSS 回调白名单、CORS 配置、邮件链接等
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 支付宝支付（套餐订阅 + 积分充值）
# -----------------------------------------------------------------------------
# 获取方式：登录 https://open.alipay.com → 控制台 → 我的应用
#           → 创建「网页/移动应用」→ 获取 AppID
#           → 开发设置 → 接口加签方式 → 公钥模式 → 生成密钥对
#           → 上传应用公钥，获取支付宝公钥
#
# 重要：
#   - 私钥仅存于服务端环境变量，禁止传入客户端或公共仓库
#   - 异步通知地址（ALIPAY_NOTIFY_URL）必须是公网可访问的 HTTPS URL
#   - 沙箱环境用于测试：https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 支付宝应用 ID（AppID）
ALIPAY_APP_ID=your_alipay_app_id

# 应用私钥（RSA2，去除 PEM 头尾和换行符的纯字符串）
ALIPAY_APP_PRIVATE_KEY=your_app_private_key

# 支付宝公钥（用于验签异步通知，由开放平台生成）
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 支付宝网关地址
# 正式环境：https://openapi.alipay.com/gateway.do
# 沙箱环境：https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 异步通知回调地址（必须公网可访问，由支付宝服务器主动 POST 调用）
# 格式：https://your-domain.com/api/payment/callback
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/callback

# 同步跳转返回地址（用户支付完成后浏览器跳回的页面，前端展示）
# 格式：https://your-domain.com/dashboard/orders
ALIPAY_RETURN_URL=https://your-domain.com/dashboard/orders

# -----------------------------------------------------------------------------
# 火山方舟 Volcengine Ark（AI 模型：豆包 / Seedream / Seedance）
# -----------------------------------------------------------------------------
# 获取方式：登录 https://console.volcengine.com/ark
#           → 开通管理 → 开通豆包/Seedream/Seedance 模型
#           → API Key 管理 → 创建 API Key
# 用途：
#   - 豆包：文本对话（/chat/completions）
#   - Seedream：文生图（/images/generations）
#   - Seedance：视频生成（/contents/generations/tasks，异步任务）
# 注意：火山方舟 /api/v3 接口为 OpenAI 兼容协议，使用 Bearer 鉴权

# 火山方舟 API Key（统一鉴权密钥）
VOLC_ARK_API_KEY=your_volc_ark_api_key

# 豆包模型 Endpoint ID（用于文本对话）
# 获取方式：火山方舟控制台 → 在线推理 → 创建推理接入点 → 复制 Endpoint ID
VOLC_MODEL_DOUBAO=ep-xxxxxxxxxxxxxxxx

# Seedream 模型 Endpoint ID（用于文生图）
VOLC_MODEL_SEEDREAM=ep-xxxxxxxxxxxxxxxx

# Seedance 视频模型 ID（用于视频生成，无需 Endpoint，直接使用模型 ID）
# 可选值（参考火山方舟最新模型列表）：
#   - doubao-seedance-1-5-pro-251215  （1.5 Pro，推荐）
#   - doubao-seedance-1-0-pro-250528  （1.0 Pro）
#   - doubao-seedance-2-0-260128      （2.0，需账户余额 > 200 元）
VOLC_MODEL_SEEDANCE=doubao-seedance-1-5-pro-251215
